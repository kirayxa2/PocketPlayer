<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>PocketPoster</string>
    <key>CFBundleExecutable</key>
    <string>PocketPoster</string>
    <key>CFBundleIdentifier</key>
    <string>com.vortex.pocketposter</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>PocketPoster</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <!--
        Home-screen icon. iOS doesn't pick up `posterPlayer.png` directly;
        it expects sized variants. scripts/gen-icons.sh regenerates them
        from the 1024x1024 master next to this file.
        For maximum jailbreak/uicache compatibility we declare the icons
        in THREE places:
          1. Top-level CFBundleIconFiles array (legacy, but universally
             honoured by uicache on rootless iOS 15).
          2. CFBundleIcons.CFBundlePrimaryIcon.CFBundleIconFiles (modern).
          3. Plain Icon.png / Icon@2x.png / Icon@3x.png filenames so
             uicache's filename heuristic also finds them.
        We deliberately do NOT use CFBundleIconName -- that key only
        works with an Asset Catalog (.car), which we don't ship.
    -->
    <key>CFBundleIconFile</key>
    <string>Icon</string>
    <key>CFBundleIconFiles</key>
    <array>
        <string>Icon</string>
        <string>Icon@2x</string>
        <string>Icon@3x</string>
        <string>Icon-60</string>
        <string>Icon-60@2x</string>
        <string>Icon-60@3x</string>
    </array>
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>Icon</string>
                <string>Icon@2x</string>
                <string>Icon@3x</string>
                <string>Icon-60</string>
                <string>Icon-60@2x</string>
                <string>Icon-60@3x</string>
            </array>
        </dict>
    </dict>
    <key>CFBundleIcons~ipad</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>Icon</string>
                <string>Icon@2x</string>
                <string>Icon@3x</string>
                <string>Icon-60</string>
                <string>Icon-60@2x</string>
                <string>Icon-60@3x</string>
                <string>Icon-76</string>
                <string>Icon-76@2x</string>
            </array>
        </dict>
    </dict>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>MinimumOSVersion</key>
    <string>15.0</string>
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
        <integer>2</integer>
    </array>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>
    <!--
        Document picker filter for .tendies imports. UTType for tendies is
        "com.apple.bezel" siblings -> in practice .tendies is just a zip;
        we declare a custom UTI so iOS lets us pick those files from
        Files.app, AirDrop, etc.
    -->
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.vortex.tendies</string>
            <key>UTTypeDescription</key>
            <string>Wallpaper Bundle</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.zip-archive</string>
                <string>public.data</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>tendies</string>
                </array>
            </dict>
        </dict>
    </array>
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Wallpaper Bundle</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.vortex.tendies</string>
                <string>public.zip-archive</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
