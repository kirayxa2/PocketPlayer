<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        We need to escape the app sandbox to write the apply manifest
        into /var/mobile/Library/PocketPlayer/, which the tweak running
        inside SpringBoard reads. On Dopamine / palera1n rootless,
        these three entitlements together grant the app full filesystem
        access (same set Trollstore-style apps ship with).

        Without this trio the app stays confined to its container and
        the Apply button silently no-ops because the tweak can't see
        the manifest.
    -->
    <key>platform-application</key>
    <true/>
    <key>com.apple.private.security.no-sandbox</key>
    <true/>
    <key>com.apple.private.security.container-required</key>
    <false/>
</dict>
</plist>
